# Canton Network Indexer — Environment Configuration

# ─── Network ──────────────────────────────────────────────
# mainnet | testnet | devnet
CANTON_NETWORK=mainnet

# Override Lighthouse URL (optional — auto-set from CANTON_NETWORK)
# LIGHTHOUSE_URL=https://lighthouse.cantonloop.com

# ─── Server ───────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────
# Full connection string (takes priority if set)
DATABASE_URL=postgres://canton:canton@postgres:5432/canton_indexer

# Or individual fields (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=canton_indexer
# DB_USER=canton
# DB_PASSWORD=canton
# DB_POOL_MAX=10

# ─── Polling intervals (seconds) ──────────────────────────
POLL_STATS_SEC=60          # price + network stats
POLL_VALIDATORS_SEC=300    # validator list + rounds
POLL_REWARDS_SEC=900       # rewards + transactions
POLL_GOVERNANCE_SEC=1800   # governance votes
POLL_SNAPSHOT_SEC=3600     # full validator snapshot (uptime)

# ─── Optional: Local Validator API (JWT-authenticated) ────
# Required for balance queries and party-specific data
VALIDATOR_API_ENABLED=false
VALIDATOR_API_URL=http://localhost:10013
VALIDATOR_JWT_TOKEN=

# ─── Optional: SV Scan API (IP-whitelisted) ───────────────
# Contact Canton Foundation to get your IP whitelisted
SCAN_API_ENABLED=false
SCAN_API_URL=

# ─── Cache ────────────────────────────────────────────────
# How long to serve stale data (ms) if upstream is down
CACHE_STALE_TTL_MS=300000

# ─── Lighthouse timeout ───────────────────────────────────
LIGHTHOUSE_TIMEOUT_MS=10000
